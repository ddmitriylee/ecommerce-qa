{
  "name": "ecommerce",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run dev -w @ecommerce/client",
    "dev:server": "cd apps/server && vercel dev",
    "build:client": "npm run build -w @ecommerce/client",
    "build:server": "npm run build -w @ecommerce/server",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm test -ws --if-present",
    "test:e2e": "npm run test:e2e -ws --if-present",
    "mutation": "node tests/mutation/mutation-runner.mjs",
    "test:perf": "cd apps/server && npx vitest run __tests__/performance",
    "test:chaos": "cd apps/server && npx vitest run __tests__/chaos"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "vercel": "^50.35.0"
  }
}
